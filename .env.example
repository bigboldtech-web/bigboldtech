# =============================================================
# Big Bold Tech — environment variables
# Copy this file to .env.local for local dev, or set in your
# hosting provider's env config for production.
# =============================================================

# Contact form delivery
# ---------------------
# A webhook URL that receives JSON POSTs of every contact-form
# submission. Works with Slack incoming webhooks, Discord
# webhooks, Zapier, n8n, or any HTTP endpoint that accepts JSON.
#
# The payload shape is:
#   { text: "<formatted summary>", lead: { name, email, ... } }
#
# Slack/Discord render the `text` field; programmatic receivers
# can read the structured `lead` object.
#
# If unset, submissions are logged to stdout and the form still
# returns success — useful for dev. In production, set this.
BBT_LEAD_WEBHOOK_URL=

# Set to "1" to make the form return a 502 error if the webhook
# fails. Leave unset to fail-soft (still return success to the
# user; you'll see the error in server logs).
BBT_REQUIRE_WEBHOOK=
